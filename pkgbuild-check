#!/usr/bin/env python3
"""
pkgbuild-check — static security analyzer for PKGBUILD files
Usage: pkgbuild-check [PKGBUILD]
       If no file is given, reads from stdin.
"""

import re
import sys
import os

# ── ANSI colours ──────────────────────────────────────────────────────────────
RESET  = "\033[0m"
BOLD   = "\033[1m"
RED    = "\033[31m"
YELLOW = "\033[33m"
GREEN  = "\033[32m"
CYAN   = "\033[36m"
DIM    = "\033[2m"
NO_COLOR = not sys.stdout.isatty()

def c(color, text):
    if NO_COLOR:
        return text
    return f"{color}{text}{RESET}"

