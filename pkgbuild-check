# ── Helpers ───────────────────────────────────────────────────────────────────

def check_list(text, checks):
    hits = []
    misses = []
    for chk in checks:
        if "fn" in chk:
            matched = chk["fn"](text)
        else:
            m = chk["re"].search(text)
            matched = bool(m)
        (hits if matched else misses).append((chk, matched))
    return hits, misses

def snippet(text, pattern):
    """Return a short matching line for display."""
    if not isinstance(pattern, re.Pattern):
        return None
    m = pattern.search(text)
    if not m:
        return None
    line = text[max(0, m.start()-20):m.end()+20].strip().replace("\n", " ")
    return line[:90] + ("…" if len(line) > 90 else "")

def score(reds, warns, goods_found, goods_total):
    penalty = len(reds) * 30 + len(warns) * 10
    bonus = min(len(goods_found) * 5, 20)
    return max(0, min(100, 100 - penalty + bonus))

# ── Rendering ─────────────────────────────────────────────────────────────────

W = 68  # terminal width

def hr(char="─"):
    print(c(DIM, char * W))

def header(path):
    print()
    label = os.path.basename(path) if path != "<stdin>" else "stdin"
    print(c(BOLD, f"  pkgbuild-check  ─  {label}"))
    hr()

def print_finding(icon, color, label, detail, snip=None):
    prefix = c(color, f"  {icon} ")
    print(f"{prefix}{c(BOLD, label)}")
    print(f"     {c(DIM, detail)}")
    if snip:
        print(f"     {c(DIM, '→')} {c(DIM, snip)}")

def print_good(label, detail):
    print(f"  {c(GREEN, '✓')} {label}")
    print(f"     {c(DIM, detail)}")

def print_missing(label, detail):
    print(f"  {c(DIM, '○')} {c(DIM, label)}")
    print(f"     {c(DIM, detail)}")

def render(text, path):
    header(path)

    red_hits, _   = check_list(text, RED_FLAGS)
    warn_hits, _  = check_list(text, WARNINGS)
    good_hits, good_miss = check_list(text, GOOD_PRACTICES)
    good_hits = [x[0] for x in good_hits]
    good_miss = [x[0] for x in good_miss]

    sc = score(red_hits, warn_hits, good_hits, GOOD_PRACTICES)

    if red_hits:
        verdict = c(RED,    c(BOLD, "HIGH RISK — do not install"))
    elif len(warn_hits) >= 2:
        verdict = c(YELLOW, c(BOLD, "SUSPICIOUS — review carefully"))
    elif len(warn_hits) == 1:
        verdict = c(YELLOW, c(BOLD, "MOSTLY FINE — one warning"))
    else:
        verdict = c(GREEN,  c(BOLD, "CLEAN"))

    print(f"  Score  {c(BOLD, str(sc))}/100   {verdict}")
    print(f"  {c(DIM, f'{len(red_hits)} critical  {len(warn_hits)} warnings  {len(good_hits)}/{len(GOOD_PRACTICES)} best practices')}")
    print()

    if red_hits:
        print(c(RED, c(BOLD, "  CRITICAL ISSUES")))
        hr()
        for chk in red_hits:
            snip = snippet(text, chk.get("re"))
            print_finding("✗", RED, chk["label"], chk["detail"], snip)
            print()

    if warn_hits:
        print(c(YELLOW, c(BOLD, "  WARNINGS")))
        hr()
        for chk in warn_hits:
            snip = snippet(text, chk.get("re"))
            print_finding("!", YELLOW, chk["label"], chk["detail"], snip)
            print()

    if good_hits:
        print(c(GREEN, c(BOLD, "  GOOD PRACTICES FOUND")))
        hr()
        for chk in good_hits:
            print_good(chk["label"], chk["detail"])
            print()

    if good_miss:
        print(c(CYAN, c(BOLD, "  BEST PRACTICES NOT DETECTED")))
        hr()
        for chk in good_miss:
            print_missing(chk["label"], chk["detail"])
            print()

    hr()
    print()
    return 2 if red_hits else (1 if warn_hits else 0)

# ── Entry point ───────────────────────────────────────────────────────────────

def main():
    args = [a for a in sys.argv[1:] if not a.startswith("-")]
    flags = [a for a in sys.argv[1:] if a.startswith("-")]

    if "-h" in flags or "--help" in flags:
        print(__doc__)
        sys.exit(0)

    if "--no-color" in flags:
        global NO_COLOR
        NO_COLOR = True

    if args:
        path = args[0]
        try:
            with open(path, "r", encoding="utf-8") as f:
                text = f.read()
        except FileNotFoundError:
            print(f"pkgbuild-check: file not found: {path}", file=sys.stderr)
            sys.exit(3)
        except PermissionError:
            print(f"pkgbuild-check: permission denied: {path}", file=sys.stderr)
            sys.exit(3)
    else:
        if sys.stdin.isatty():
            print("pkgbuild-check: reading from stdin (pass a filename or pipe a PKGBUILD)", file=sys.stderr)
        text = sys.stdin.read()
        path = "<stdin>"

    exit_code = render(text, path)
    sys.exit(exit_code)

if __name__ == "__main__":
    main()
